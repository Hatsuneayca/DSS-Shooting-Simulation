def export_trajectory_csv(times, traj, speeds, path: str):
    with open(path, "w", newline="") as f:
        w = csv.writer(f)
        w.writerow(["time_s", "X_m", "Y_m", "Z_m", "speed_ms"])
        for t, p, s in zip(times, traj, speeds):
            w.writerow([f"{t:.4f}", f"{p[0]:.4f}", f"{p[1]:.4f}",
                        f"{p[2]:.4f}", f"{s:.4f}"])
    print(f"  → Trajectory CSV: {path}")


def export_montecarlo_csv(mc_result: dict, path: str):
    with open(path, "w", newline="") as f:
        w = csv.writer(f)
        w.writerow(["hit_Y_m", "hit_Z_m"])
        for y, z in zip(mc_result["hits_y"], mc_result["hits_z"]):
            w.writerow([f"{y:.5f}", f"{z:.5f}"])
    print(f"  → Monte Carlo CSV: {path}")


