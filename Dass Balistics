def plot_all(times, traj, speeds, correction, mc_result,
             env, imu, target_range):

    X, Y, Z = traj[:, 0], traj[:, 1], traj[:, 2]
    los      = correction["los"]
    poi      = correction["poi"]
    delta    = correction["delta"]

    fig = plt.figure(figsize=(18, 10), facecolor="#f9f9f9")
    fig.suptitle("DASS — Balistik & Düzeltme Motoru v3.0",
                 fontsize=14, fontweight="bold", y=0.98)

    # ── 3D Yörünge ───────────────────────────────────────────────────────
    ax1 = fig.add_subplot(231, projection="3d")
    ax1.plot(X, Y, Z, color="crimson", lw=2, label="Balistik yörünge")
    ax1.scatter(*poi, color="navy",   s=60, zorder=5, label=f"PoI @{target_range}m")
    ax1.scatter(*los, color="lime",   s=60, zorder=5, label=f"LoS @{target_range}m",
                marker="^")
    ax1.set_title("3D Balistik Yörünge")
    ax1.set_xlabel("X [m]"); ax1.set_ylabel("Y [m]"); ax1.set_zlabel("Z [m]")
    ax1.legend(fontsize=7)

    # ── Hedef Düzlemi: LoS vs PoI ────────────────────────────────────────
    ax2 = fig.add_subplot(232)
    ax2.axhline(0, color="gray", ls="--", lw=0.7)
    ax2.axvline(0, color="gray", ls="--", lw=0.7)
    ax2.plot(0, 0, "k+", ms=18, mew=2.5, label="Kamera merkezi (0,0)")
    ax2.plot(los[1], los[2], "g^", ms=10,
             label=f"LoS (lazer)  Y={los[1]:.3f} Z={los[2]:.3f} m")
    ax2.plot(poi[1], poi[2], "ro", ms=10,
             label=f"PoI (mermi)  Y={poi[1]:.3f} Z={poi[2]:.3f} m")
    ax2.annotate("", xy=(poi[1], poi[2]), xytext=(los[1], los[2]),
                 arrowprops=dict(arrowstyle="->", color="purple", lw=2))
    ax2.text((los[1]+poi[1])/2 + 0.01, (los[2]+poi[2])/2,
             f"Δ = ({delta[1]:.3f}, {delta[2]:.3f}) m",
             color="purple", fontsize=8, fontweight="bold")
    ax2.set_title(f"Hedef Düzlemi @{target_range}m — LoS vs PoI")
    ax2.set_xlabel("Yanal Y [m]"); ax2.set_ylabel("Yükseklik Z [m]")
    ax2.axis("equal"); ax2.grid(True, alpha=0.4)
    ax2.legend(fontsize=7)

    # ── Monte Carlo Dağılımı ─────────────────────────────────────────────
    ax3 = fig.add_subplot(233)
    ax3.scatter(mc_result["hits_y"], mc_result["hits_z"],
                s=6, alpha=0.35, color="steelblue", label=f"N={len(mc_result['hits_y'])} atış")
    ax3.plot(mc_result["mean_y"], mc_result["mean_z"],
             "r+", ms=14, mew=2.5, label=f"Ortalama PoI")

    # %95 güven elipsi
    ell = mc_result["ellipse"]
    e95 = Ellipse(xy=(mc_result["mean_y"], mc_result["mean_z"]),
                  width=ell["width"], height=ell["height"],
                  angle=ell["angle"],
                  edgecolor="red", facecolor="none", lw=1.8,
                  label=f"%95 elips ({ell['width']*100:.1f}×{ell['height']*100:.1f} cm)")
    ax3.add_patch(e95)
    ax3.set_title(f"Monte Carlo Etki Dağılımı @{target_range}m\n"
                  f"CEP mean={mc_result['cep_mean_m']*100:.1f}cm  "
                  f"target={mc_result['cep_target_m']*100:.1f}cm")
    ax3.set_xlabel("Y [m]"); ax3.set_ylabel("Z [m]")
    ax3.axis("equal"); ax3.grid(True, alpha=0.4)
    ax3.legend(fontsize=7)

    # ── Hız–Menzil (Mach) ────────────────────────────────────────────────
    ax4 = fig.add_subplot(234)
    c = env.c_sound
    ax4.plot(X, speeds, color="steelblue", lw=2, label="Mermi hızı")
    ax4.axhline(c,       color="red",    ls="--", lw=1, label=f"Ses ({c} m/s)")
    ax4.axhline(c*0.8,   color="orange", ls=":",  lw=1, label="Mach 0.8")
    ax4.fill_between(X, c*0.8, c, alpha=0.07, color="orange")
    ax4.set_title("Hız — Menzil"); ax4.set_xlabel("X [m]"); ax4.set_ylabel("Hız [m/s]")
    ax4.legend(fontsize=7); ax4.grid(True, alpha=0.4)

    # ── Latency Budget (yatay bar) ────────────────────────────────────────
    ax5 = fig.add_subplot(235)
    labels = list(LATENCY_BUDGET.keys())
    values = list(LATENCY_BUDGET.values())
    total  = sum(values)
    colors = ["#4CAF50","#2196F3","#FF9800","#9C27B0","#607D8B"]
    bars   = ax5.barh(labels, values, color=colors, edgecolor="white", height=0.6)
    for bar, val in zip(bars, values):
        ax5.text(val + 0.1, bar.get_y() + bar.get_height()/2,
                 f"{val:.2f} ms", va="center", fontsize=8)
    ax5.axvline(LATENCY_TARGET_MS, color="red", ls="--", lw=1.5,
                label=f"Hedef < {LATENCY_TARGET_MS} ms")
    ax5.axvline(total, color="navy", ls="-", lw=1.5,
                label=f"Toplam = {total:.2f} ms")
    ax5.set_xlabel("Süre [ms]")
    ax5.set_title("Pipeline Gecikme Bütçesi")
    ax5.legend(fontsize=7); ax5.grid(True, alpha=0.3, axis="x")
    ax5.set_xlim(0, LATENCY_TARGET_MS * 1.1)
    labels_short = [l.split("(")[0].strip() for l in labels]
    ax5.set_yticks(range(len(labels_short)))
    ax5.set_yticklabels(labels_short, fontsize=7)

    # ── Correction Özet Tablosu ──────────────────────────────────────────
    ax6 = fig.add_subplot(236)
    ax6.axis("off")
    rows = [
        ["", "Y [m]", "Z [m]"],
        ["LoS (lazer)",  f"{los[1]:+.4f}", f"{los[2]:+.4f}"],
        ["PoI (mermi)",  f"{poi[1]:+.4f}", f"{poi[2]:+.4f}"],
        ["Δ correction", f"{delta[1]:+.4f}", f"{delta[2]:+.4f}"],
        ["Kant offset",  f"{correction['cant']:+.4f}", "—"],
        ["Toplam yanal", f"{correction['total_lateral_error']:+.4f}", "—"],
        ["", "", ""],
        ["Latency toplamı", f"{total:.2f} ms", "✓" if total < LATENCY_TARGET_MS else "✗"],
        ["CEP mean-ctr",   f"{mc_result['cep_mean_m']*100:.1f} cm", ""],
        ["CEP target-ctr", f"{mc_result['cep_target_m']*100:.1f} cm", ""],
    ]
    tbl = ax6.table(cellText=rows, loc="center", cellLoc="center")
    tbl.auto_set_font_size(False); tbl.set_fontsize(9)
    tbl.scale(1.3, 1.6)
    for (r, c_), cell in tbl.get_celld().items():
        if r == 0:
            cell.set_facecolor("#34495e"); cell.set_text_props(color="white", fontweight="bold")
        elif r % 2 == 0:
            cell.set_facecolor("#ecf0f1")
    ax6.set_title("Düzeltme & Sistem Özeti", fontweight="bold")

    plt.tight_layout(rect=[0, 0, 1, 0.96])
    out = "/mnt/user-data/outputs/dass_ballistics_v3.png"
    plt.savefig(out, dpi=150, bbox_inches="tight")
    print(f"  → Grafik: {out}")
    plt.show()


